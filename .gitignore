# Ignore bundler config.
/.bundle

# Ignore environment files.
.env*

# Ignore Rails secrets.
/config/master.key
/config/credentials/*.key
/.kamal/secrets

# Ignore runtime files.
/log/*
/tmp/*
!/log/.keep
!/tmp/.keep
!/tmp/pids
!/tmp/pids/.keep
!/tmp/storage
!/tmp/storage/.keep

# Ignore uploaded files in development.
/storage/*
!/storage/.keep

# Ignore compiled assets.
/public/assets
/app/assets/builds/*
!/app/assets/builds/.keep

# Ignore local databases.
/db/*.sqlite3
/db/*.sqlite3-*

/tmp/pids/*
!/tmp/pids/.keep
