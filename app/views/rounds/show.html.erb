<main class="mx-auto w-full max-w-5xl px-4 py-10 sm:px-6 sm:py-14 lg:px-8 lg:py-20">
  <% actions = link_to "Fixtures", root_path, class: "rounded-xl border border-slate-200 bg-white px-4 py-3 text-center text-sm font-bold text-slate-700 shadow-sm transition hover:bg-slate-50" %>

  <%= render "shared/page_header", title: (@grouped ? "Group stage" : @round_number), description: "Round #{@round_number}", actions: actions %>

  <% if @fixtures.any? %>
    <div class="grid gap-6">
      <% @groups.each do |group_name, fixtures| %>
        <section class="overflow-hidden rounded-3xl border border-slate-200 bg-white shadow-sm shadow-slate-200/70">
          <h2 class="border-b border-slate-200 bg-slate-50 px-5 py-4 text-xl font-black text-slate-950"><%= group_name.presence || @round_number %></h2>

          <div class="divide-y divide-slate-100">
            <% fixtures.each do |fixture| %>
              <%= link_to fixture_path(fixture), class: "grid gap-2 px-5 py-4 transition hover:bg-slate-50 sm:grid-cols-[7rem_minmax(0,1fr)_minmax(0,1fr)] sm:items-center" do %>
                <time class="text-sm font-extrabold text-amber-600" datetime="<%= fixture.match_date.iso8601 %>" data-local-time="short"><%= fixture.match_date.in_time_zone("Pacific Time (US & Canada)").strftime("%-m/%-d %-I:%M %p PT") %></time>
                <div class="min-w-0 text-sm font-black text-slate-950 sm:text-base">
                  <span><%= team_name_with_flag(fixture.home_team) %></span>
                  <span class="mx-2 text-slate-400"><%= fixture.result? ? "#{fixture.home_score}–#{fixture.away_score}" : "v" %></span>
                  <span><%= team_name_with_flag(fixture.away_team) %></span>
                </div>
                <p class="min-w-0 truncate text-sm text-slate-500 sm:text-right"><%= venue(fixture.location) %></p>
              <% end %>
            <% end %>
          </div>
        </section>
      <% end %>
    </div>
  <% else %>
    <section class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm shadow-slate-200/70 sm:rounded-3xl sm:p-8">
      <h2 class="text-2xl font-black text-slate-950">No fixtures found</h2>
      <p class="mt-2 text-slate-600">This round has no games.</p>
    </section>
  <% end %>
</main>
