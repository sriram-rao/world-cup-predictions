<main class="mx-auto w-full max-w-5xl px-4 py-10 sm:px-6 sm:py-14 lg:px-8 lg:py-20">
  <header class="mb-8 flex items-start justify-between gap-4 sm:mb-10">
    <div>
      <p class="text-sm font-bold uppercase tracking-widest text-slate-500">World Cup Predictions</p>
      <form class="relative mt-2 inline-block">
        <button type="button"
          onclick="const select = this.form.querySelector('select'); select.showPicker ? select.showPicker() : select.click();"
          class="text-left text-4xl font-black tracking-tight text-slate-950 transition hover:text-blue-700 sm:text-6xl lg:text-7xl">
          <%= @group_name %> <span class="text-2xl text-slate-400">▾</span>
        </button>
        <select class="absolute inset-0 h-full w-full cursor-pointer opacity-0"
          style="color: #0f172a; background: #fff;"
          onchange="if (this.value) window.location = this.value">
          <%= options_for_select(@group_names.map { |group| [group, group_path(group)] }, group_path(@group_name)) %>
        </select>
      </form>
      <p class="mt-4 text-base text-slate-600 sm:text-lg">Standings and fixtures</p>
    </div>

    <%= link_to "Fixtures", root_path, class: "rounded-xl border border-slate-200 bg-white px-4 py-3 text-center text-sm font-bold text-slate-700 shadow-sm transition hover:bg-slate-50" %>
  </header>

  <% if @fixtures.any? %>
    <section class="mb-6 overflow-hidden rounded-3xl border border-slate-200 bg-white shadow-sm shadow-slate-200/70">
      <div class="grid grid-cols-[minmax(0,1fr)_1.5rem_1.5rem_1.5rem_1.5rem_2.25rem_2.25rem] gap-1 border-b border-slate-200 bg-slate-50 px-4 py-3 text-xs font-black uppercase tracking-wide text-slate-500 sm:px-6">
        <span>Team</span>
        <span class="text-right">P</span>
        <span class="text-right">W</span>
        <span class="text-right">D</span>
        <span class="text-right">L</span>
        <span class="text-right">GD</span>
        <span class="text-right">Pts</span>
      </div>

      <% @standings.each do |row| %>
        <div class="grid grid-cols-[minmax(0,1fr)_1.5rem_1.5rem_1.5rem_1.5rem_2.25rem_2.25rem] gap-1 border-b border-slate-100 px-4 py-3 text-sm last:border-b-0 sm:px-6">
          <span class="min-w-0 truncate font-black text-slate-950"><%= team_name_with_flag(row[:team]) %></span>
          <span class="text-right font-bold text-slate-600"><%= row[:played] %></span>
          <span class="text-right font-bold text-slate-600"><%= row[:won] %></span>
          <span class="text-right font-bold text-slate-600"><%= row[:drawn] %></span>
          <span class="text-right font-bold text-slate-600"><%= row[:lost] %></span>
          <span class="text-right font-bold text-slate-600"><%= row[:goals_for] - row[:goals_against] %></span>
          <span class="text-right font-black text-slate-950"><%= row[:points] %></span>
        </div>
      <% end %>
    </section>

    <section class="overflow-hidden rounded-3xl border border-slate-200 bg-white shadow-sm shadow-slate-200/70">
      <h2 class="border-b border-slate-200 bg-slate-50 px-5 py-4 text-xl font-black text-slate-950">Fixtures</h2>

      <div class="divide-y divide-slate-100">
        <% @fixtures.each do |fixture| %>
          <div class="grid gap-2 px-5 py-4 sm:grid-cols-[7rem_minmax(0,1fr)_minmax(0,1fr)] sm:items-center">
            <time class="text-sm font-extrabold text-amber-600"><%= fixture.match_date.in_time_zone("Pacific Time (US & Canada)").strftime("%-m/%-d %-I:%M %p") %></time>
            <div class="flex min-w-0 items-center gap-3">
              <div class="min-w-0 flex-1 text-sm font-black text-slate-950 sm:text-base">
                <span><%= team_name_with_flag(fixture.home_team) %></span>
                <span class="mx-2 text-slate-400"><%= fixture.result? ? "#{fixture.home_score}–#{fixture.away_score}" : "v" %></span>
                <span><%= team_name_with_flag(fixture.away_team) %></span>
              </div>
              <%= link_to "Predictions", fixture_path(fixture), class: "shrink-0 rounded-xl border border-slate-200 bg-white px-3 py-2 text-center text-sm font-bold text-blue-700 transition hover:bg-slate-50 hover:text-blue-800" %>
            </div>
            <p class="min-w-0 truncate text-sm text-slate-500 sm:text-right"><%= venue(fixture.location) %></p>
          </div>
        <% end %>
      </div>
    </section>
  <% else %>
    <section class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm shadow-slate-200/70 sm:rounded-3xl sm:p-8">
      <h2 class="text-2xl font-black text-slate-950">No fixtures found</h2>
      <p class="mt-2 text-slate-600">This group has no games.</p>
    </section>
  <% end %>
</main>
