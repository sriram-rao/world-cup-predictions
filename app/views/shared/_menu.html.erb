<details class="relative z-50 shrink-0" data-click-outside-close>
  <summary class="list-none rounded-xl border border-slate-200 bg-white px-4 py-3 text-sm font-black text-slate-700 shadow-sm marker:hidden">
    ☰
  </summary>

  <div class="absolute right-0 z-10 mt-2 w-56 overflow-hidden rounded-2xl border border-slate-200 bg-white text-sm font-bold text-slate-700 shadow-xl">
    <% if authenticated? %>
      <div class="border-b border-slate-100 px-4 py-3 text-slate-500">Hi <%= Current.user.username %></div>
    <% else %>
      <%= link_to "Sign in", new_session_path, class: "block border-b border-slate-100 px-4 py-3 transition hover:bg-slate-50" %>
      <%= link_to "Sign up", new_registration_path, class: "block border-b border-slate-100 px-4 py-3 transition hover:bg-slate-50" %>
    <% end %>

    <%= link_to "Fixtures", root_path, class: "block border-b border-slate-100 px-4 py-3 transition hover:bg-slate-50" %>
    <%= link_to "Leaderboard", leaderboard_path, class: "block border-b border-slate-100 px-4 py-3 transition hover:bg-slate-50" %>
    <% Leaderboard.active.where.not(slug: Leaderboard::STANDARD_SLUG).each do |leaderboard| %>
      <%= link_to leaderboard.name, named_leaderboard_path(leaderboard.slug), class: "block border-b border-slate-100 px-4 py-3 transition hover:bg-slate-50" %>
    <% end %>
    <%= link_to "Rules", scoring_rules_path, class: "block border-b border-slate-100 px-4 py-3 transition hover:bg-slate-50" %>

    <button type="button" data-theme-toggle class="flex w-full items-center gap-2 border-b border-slate-100 px-4 py-3 text-left font-bold transition hover:bg-slate-50">
      <span data-theme-toggle-icon>☀️</span>
      <span data-theme-toggle-label>Light mode</span>
    </button>

    <% if authenticated? && Current.user.admin? %>
      <%= button_to "Admin mode: #{admin_mode? ? "On" : "Off"}", admin_mode_path,
        method: :patch,
        params: { enabled: !admin_mode? },
        class: "w-full border-b border-slate-100 px-4 py-3 text-left font-bold transition hover:bg-slate-50" %>
    <% end %>

    <% if authenticated? %>
      <%= button_to "Sign out", session_path, method: :delete, class: "w-full px-4 py-3 text-left font-bold transition hover:bg-slate-50" %>
    <% end %>
  </div>
</details>
