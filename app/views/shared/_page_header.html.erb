<header class="mb-8 sm:mb-10">
  <p class="text-sm font-bold uppercase tracking-widest text-slate-500">World Cup Predictions</p>

  <div class="mt-2 flex items-start justify-between gap-4">
    <div class="min-w-0">
      <div class="flex min-w-0 items-center gap-3">
        <h1 class="<%= local_assigns.fetch(:title_class, "text-4xl font-black tracking-tight text-slate-950 sm:text-6xl lg:text-7xl") %>">
          <%= title %>
        </h1>
        <%= local_assigns[:title_extra] %>
      </div>
      <% if local_assigns[:description].present? %>
        <p class="mt-4 text-base text-slate-600 sm:text-lg"><%= description %></p>
      <% end %>
    </div>

    <%= render "shared/menu" %>
  </div>

  <% if local_assigns[:actions].present? %>
    <div class="mt-4"><%= actions %></div>
  <% end %>
</header>
