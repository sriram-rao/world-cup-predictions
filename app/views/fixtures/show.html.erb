<main class="mx-auto w-full max-w-3xl px-4 py-10 sm:px-6 sm:py-14 lg:px-8 lg:py-20">
  <header class="mb-8">
    <div class="flex items-center justify-between gap-4">
      <p class="text-sm font-bold uppercase tracking-widest text-slate-500">World Cup Predictions</p>
      <%= link_to "← Back", root_path(date: @back_date), class: "shrink-0 text-sm font-bold text-slate-600 transition hover:text-slate-950" %>
    </div>

    <h1 class="mt-4 text-2xl font-black leading-tight text-slate-950 sm:text-4xl lg:text-5xl">
      <%= team_name_with_flag(@fixture.home_team) %>
      <span class="text-slate-400"><%= @fixture.result? ? "#{@fixture.home_score}–#{@fixture.away_score}" : "v" %></span>
      <%= team_name_with_flag(@fixture.away_team) %>
    </h1>

    <p class="mt-3 text-sm text-slate-500">
      <%= @fixture.match_date.in_time_zone("Pacific Time (US & Canada)").strftime("%A, %B %-d · %-I:%M %p PT") %>
      · <%= venue(@fixture.location) %>
      <% if @fixture.group_name.present? %> · <%= @fixture.group_name %><% end %>
    </p>
  </header>

  <% if flash[:notice].present? %>
    <div class="mb-6 rounded-2xl border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm font-semibold text-emerald-700"><%= flash[:notice] %></div>
  <% end %>

  <% if flash[:alert].present? %>
    <div class="mb-6 rounded-2xl border border-red-200 bg-red-50 px-4 py-3 text-sm font-semibold text-red-700"><%= flash[:alert] %></div>
  <% end %>

  <section class="overflow-hidden rounded-3xl border border-slate-200 bg-white shadow-sm shadow-slate-200/70">
    <div class="grid grid-cols-[minmax(0,1fr)_5rem_5rem] gap-3 border-b border-slate-200 bg-slate-50 px-4 py-3 text-xs font-black uppercase tracking-wide text-slate-500 sm:px-6">
      <span>Player</span>
      <span class="text-center">Pick</span>
      <span class="text-right"><%= @fixture.result? ? "Points" : "—" %></span>
    </div>

    <% if @predictions.any? %>
      <ol>
        <% @predictions.each do |prediction| %>
          <li class="grid grid-cols-[minmax(0,1fr)_5rem_5rem] items-center gap-3 border-b border-slate-100 px-4 py-3 last:border-b-0 sm:px-6 <%= "bg-blue-50" if prediction == @user_prediction %>">
            <span class="min-w-0 truncate text-sm font-black text-slate-950">
              <%= prediction.user.username %>
              <% if prediction == @user_prediction %><span class="ml-1 text-xs font-bold text-blue-600">(you)</span><% end %>
            </span>
            <span class="text-center text-sm font-black text-slate-700"><%= prediction.home_score %>–<%= prediction.away_score %></span>
            <span class="text-right text-sm font-black text-slate-950"><%= @fixture.result? ? prediction.points(@rule) : "—" %></span>
          </li>
        <% end %>
      </ol>
    <% else %>
      <div class="px-4 py-6 sm:px-6">
        <p class="text-sm text-slate-500">No predictions yet.</p>
      </div>
    <% end %>
  </section>
</main>
