<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "World Cup Predictions" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="World Cup Predictions">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <script>
      (() => {
        const theme = localStorage.getItem("theme") || "dark";
        document.documentElement.dataset.theme = theme;
      })();
    </script>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-slate-50 text-slate-900 antialiased">
    <%= yield %>

    <script>
      (() => {
        const sync = () => {
          const dark = document.documentElement.dataset.theme !== "light";
          document.querySelectorAll("[data-theme-toggle-icon]").forEach((icon) => icon.textContent = dark ? "☀️" : "🌙");
          document.querySelectorAll("[data-theme-toggle-label]").forEach((label) => label.textContent = dark ? "Light mode" : "Dark mode");
        };

        document.querySelectorAll("[data-theme-toggle]").forEach((button) => {
          button.addEventListener("click", () => {
            const next = document.documentElement.dataset.theme === "dark" ? "light" : "dark";
            document.documentElement.dataset.theme = next;
            localStorage.setItem("theme", next);
            sync();
          });
        });

        sync();
      })();

      (() => {
        const formats = {
          time: { hour: "numeric", minute: "2-digit", timeZoneName: "short" },
          short: { month: "numeric", day: "numeric", hour: "numeric", minute: "2-digit", timeZoneName: "short" },
          full: { weekday: "long", month: "long", day: "numeric", hour: "numeric", minute: "2-digit", timeZoneName: "short" }
        };

        document.querySelectorAll("time[data-local-time]").forEach((time) => {
          const date = new Date(time.dateTime);
          const format = formats[time.dataset.localTime] || formats.time;
          if (!Number.isNaN(date.valueOf())) time.textContent = new Intl.DateTimeFormat(undefined, format).format(date);
        });
      })();

      (() => {
        const timers = new WeakMap();

        const statusFor = (form) => form.querySelector("[data-autosave-status]");
        const setStatus = (form, text, classes = "text-slate-400") => {
          const status = statusFor(form);
          if (!status) return;
          status.textContent = text;
          status.className = `mt-2 text-center text-xs font-bold ${classes}`;
        };

        const updatePenaltyWinner = (form) => {
          const container = form.querySelector("[data-penalty-winner]");
          if (!container) return;

          const home = form.querySelector("[data-score-side='home']")?.value;
          const away = form.querySelector("[data-score-side='away']")?.value;
          const show = home !== "" && away !== "" && Number(home) === Number(away);
          container.classList.toggle("hidden", !show);
        };

        document.querySelectorAll("form[data-autosave-prediction]").forEach(updatePenaltyWinner);

        const save = async (form) => {
          if (!form.checkValidity()) {
            setStatus(form, "Auto-saves");
            return;
          }

          setStatus(form, "Saving...", "text-amber-600");

          try {
            const response = await fetch(form.action, {
              method: "POST",
              headers: { "Accept": "application/json" },
              body: new FormData(form),
              credentials: "same-origin"
            });

            if (response.ok) {
              setStatus(form, "Saved", "text-emerald-600");
            } else {
              setStatus(form, "Save failed", "text-red-600");
            }
          } catch (_error) {
            setStatus(form, "Save failed", "text-red-600");
          }
        };

        const schedule = (form, delay) => {
          clearTimeout(timers.get(form));
          setStatus(form, "Saving...", "text-amber-600");
          timers.set(form, setTimeout(() => save(form), delay));
        };

        document.addEventListener("input", (event) => {
          const form = event.target.closest?.("form[data-autosave-prediction]");
          if (form) {
            updatePenaltyWinner(form);
            schedule(form, 600);
          }
        });

        document.addEventListener("change", (event) => {
          const form = event.target.closest?.("form[data-autosave-prediction]");
          if (form) {
            updatePenaltyWinner(form);
            schedule(form, 0);
          }
        });
      })();

      document.addEventListener("click", (event) => {
        document.querySelectorAll("details[data-click-outside-close][open]").forEach((details) => {
          if (!details.contains(event.target)) details.removeAttribute("open");
        });

        if (event.target instanceof HTMLDialogElement) event.target.close();
      });
    </script>
  </body>
</html>
