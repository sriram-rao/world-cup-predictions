<main class="flex min-h-screen items-center justify-center bg-slate-50 px-4 py-12 sm:px-6 lg:px-8">
  <section class="w-full max-w-md rounded-3xl border border-slate-200 bg-white p-6 shadow-sm shadow-slate-200/70 sm:p-8">
    <div class="mb-8">
      <p class="text-sm font-bold uppercase tracking-widest text-slate-500">World Cup Predictions</p>
      <h1 class="mt-2 text-3xl font-black tracking-tight text-slate-950 sm:text-4xl">Sign in</h1>
      <p class="mt-3 text-sm leading-6 text-slate-600">Enter your username and password to make match predictions.</p>
    </div>

    <% if flash[:alert].present? %>
      <div class="mb-5 rounded-2xl border border-red-200 bg-red-50 px-4 py-3 text-sm font-medium text-red-700">
        <%= flash[:alert] %>
      </div>
    <% end %>

    <% if flash[:notice].present? %>
      <div class="mb-5 rounded-2xl border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm font-medium text-emerald-700">
        <%= flash[:notice] %>
      </div>
    <% end %>

    <%= form_with url: session_path, class: "space-y-5" do |form| %>
      <div>
        <%= form.label :username, "Username", class: "block text-sm font-bold text-slate-700" %>
        <%= form.text_field :username,
          required: true,
          autofocus: true,
          autocomplete: "username",
          placeholder: "your_username",
          value: params[:username],
          class: "mt-2 w-full rounded-2xl border border-slate-300 bg-white px-4 py-3 text-slate-950 outline-none transition placeholder:text-slate-400 focus:border-blue-600 focus:ring-4 focus:ring-blue-100" %>
      </div>

      <div>
        <%= form.label :password, "Password", class: "block text-sm font-bold text-slate-700" %>
        <%= form.password_field :password,
          required: true,
          autocomplete: "current-password",
          placeholder: "••••••••",
          maxlength: 72,
          class: "mt-2 w-full rounded-2xl border border-slate-300 bg-white px-4 py-3 text-slate-950 outline-none transition placeholder:text-slate-400 focus:border-blue-600 focus:ring-4 focus:ring-blue-100" %>
      </div>

      <%= form.submit "Sign in", class: "w-full cursor-pointer rounded-2xl bg-slate-950 px-5 py-3 text-sm font-black text-white shadow-sm transition hover:bg-slate-800 focus:outline-none focus:ring-4 focus:ring-slate-300" %>
    <% end %>

    <p class="mt-6 text-center text-sm text-slate-500">
      No account yet?
      <%= link_to "Create one", new_registration_path, class: "font-bold text-blue-700 hover:text-blue-800" %>
    </p>
  </section>
</main>
