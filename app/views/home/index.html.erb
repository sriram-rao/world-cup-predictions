<main class="mx-auto w-full max-w-5xl px-4 py-10 sm:px-6 sm:py-14 lg:px-8 lg:py-20">
  <header class="mb-8 sm:mb-10">
    <p class="text-sm font-bold uppercase tracking-widest text-slate-500">World Cup Predictions</p>

    <div class="mt-2 flex items-start justify-between gap-4">
      <div class="flex min-w-0 items-center gap-3">
        <h1 class="text-4xl font-black tracking-tight text-slate-950 sm:text-6xl lg:text-7xl">
          <%= @fixture_date == Time.zone.today ? "Today's fixtures" : "Fixtures" %>
        </h1>
        <%= link_to "FotMob ↗", "https://www.fotmob.com/leagues/77/fixtures/world-cup?group=by-date",
          target: "_blank",
          rel: "noopener noreferrer",
          class: "shrink-0 rounded-lg border border-slate-200 bg-white px-2.5 py-1.5 text-sm font-black text-slate-500 shadow-sm transition hover:bg-slate-50 hover:text-slate-950",
          aria: { label: "Open World Cup fixtures on FotMob in a new tab" } %>
      </div>

      <details class="relative shrink-0" data-click-outside-close>
        <summary class="list-none rounded-xl border border-slate-200 bg-white px-4 py-3 text-sm font-black text-slate-700 shadow-sm marker:hidden">
          ☰
        </summary>

        <div class="absolute right-0 z-10 mt-2 w-56 overflow-hidden rounded-2xl border border-slate-200 bg-white text-sm font-bold text-slate-700 shadow-xl">
          <% if authenticated? %>
            <div class="border-b border-slate-100 px-4 py-3 text-slate-500">Hi <%= Current.user.username %></div>
          <% else %>
            <%= link_to "Sign in", new_session_path, class: "block border-b border-slate-100 px-4 py-3 transition hover:bg-slate-50" %>
            <%= link_to "Sign up", new_registration_path, class: "block border-b border-slate-100 px-4 py-3 transition hover:bg-slate-50" %>
          <% end %>
          <%= link_to "Leaderboard", leaderboard_path, class: "block border-b border-slate-100 px-4 py-3 transition hover:bg-slate-50" %>
          <%= link_to "Rules", scoring_rules_path, class: "block border-b border-slate-100 px-4 py-3 transition hover:bg-slate-50" %>
          <button type="button" data-theme-toggle class="flex w-full items-center gap-2 border-b border-slate-100 px-4 py-3 text-left font-bold transition hover:bg-slate-50">
            <span data-theme-toggle-icon>☀️</span>
            <span data-theme-toggle-label>Light mode</span>
          </button>
          <% if authenticated? && Current.user.admin? %>
            <%= button_to "Admin mode: #{admin_mode? ? "On" : "Off"}", admin_mode_path,
              method: :patch,
              params: { enabled: !admin_mode? },
              class: "w-full border-b border-slate-100 px-4 py-3 text-left font-bold transition hover:bg-slate-50" %>
          <% end %>
          <% if authenticated? %>
            <%= button_to "Sign out", session_path, method: :delete, class: "w-full px-4 py-3 text-left font-bold transition hover:bg-slate-50" %>
          <% end %>
        </div>
      </details>
    </div>

    <div class="mt-4 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
      <%= form_with url: root_path, method: :get, class: "relative inline-block" do |form| %>
        <button type="button"
          onclick="const input = this.form.querySelector('input[type=date]'); input.showPicker ? input.showPicker() : input.click();"
          class="inline-flex cursor-pointer items-center gap-2 text-base font-semibold text-slate-600 transition hover:text-slate-950 sm:text-lg">
          <span aria-hidden="true">📅</span>
          <span><%= @fixture_date.strftime("%A, %B %-d, %Y") %> Pacific Time</span>
        </button>
        <%= form.date_field :date,
          value: @fixture_date.iso8601,
          onchange: "this.form.requestSubmit()",
          class: "absolute left-0 top-0 h-px w-px opacity-0" %>
      <% end %>

      <nav class="grid w-full grid-cols-3 overflow-hidden rounded-xl border border-slate-200 bg-white shadow-sm sm:w-64" aria-label="Fixture date navigation">
        <%= link_to "←", root_path(date: @previous_date.iso8601), class: "border-r border-slate-200 px-4 py-3 text-center text-sm font-semibold text-slate-700 transition hover:bg-slate-50" %>
        <%= link_to "Today", root_path, class: "border-r border-slate-200 px-4 py-3 text-center text-sm font-semibold text-slate-700 transition hover:bg-slate-50" %>
        <%= link_to "→", root_path(date: @next_date.iso8601), class: "px-4 py-3 text-center text-sm font-semibold text-slate-700 transition hover:bg-slate-50" %>
      </nav>
    </div>
  </header>

  <% if flash[:notice].present? %>
    <div class="mb-6 rounded-2xl border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm font-semibold text-emerald-700"><%= flash[:notice] %></div>
  <% end %>

  <% if flash[:alert].present? %>
    <div class="mb-6 rounded-2xl border border-red-200 bg-red-50 px-4 py-3 text-sm font-semibold text-red-700"><%= flash[:alert] %></div>
  <% end %>

  <% if @fixtures.any? %>
    <section class="grid gap-4 lg:grid-cols-2" aria-label="Fixtures">
      <%= render partial: "fixture", collection: @fixtures, locals: { predictions_by_fixture_id: @predictions_by_fixture_id } %>
    </section>
  <% else %>
    <section class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm shadow-slate-200/70 sm:rounded-3xl sm:p-8">
      <h2 class="text-2xl font-black text-slate-950">No fixtures today</h2>
      <p class="mt-2 text-slate-600">Check back when matchday starts.</p>
    </section>
  <% end %>
</main>
