<% prediction = predictions_by_fixture_id[fixture.id] || Prediction.new(fixture: fixture) %>
<% signed_in = authenticated? %>
<% admin = admin_mode? %>
<% open = signed_in && !fixture.locked? %>
<% row = "mt-3 grid gap-3 sm:grid-cols-[minmax(0,1fr)_8rem] sm:items-center" %>
<% scoreline = "grid grid-cols-[minmax(0,1fr)_3rem_1rem_3rem_minmax(0,1fr)] items-center gap-2 sm:grid-cols-[minmax(0,1fr)_4rem_1rem_4rem_minmax(0,1fr)] sm:gap-3" %>
<% score_input = "h-9 w-9 justify-self-center rounded-lg border border-slate-300 bg-white px-1 text-center text-base font-black outline-none focus:border-blue-600 focus:ring-4 focus:ring-blue-100 sm:h-12 sm:w-12 sm:text-xl lg:text-2xl" %>
<% result_input = "h-8 w-9 justify-self-center rounded-lg border border-slate-300 bg-white px-1 text-center text-sm font-black text-slate-950 outline-none focus:border-blue-600 focus:ring-4 focus:ring-blue-100 sm:h-9 sm:w-12 sm:text-base" %>
<% result_panel = "rounded-2xl bg-slate-100 px-3 py-3" %>
<% primary_button = "w-full cursor-pointer rounded-xl bg-slate-950 px-4 py-3 text-sm font-black text-white transition hover:bg-slate-800" %>
<% secondary_button = "w-full cursor-pointer rounded-xl border border-slate-300 bg-white px-4 py-2 text-sm font-black text-slate-700 transition hover:bg-slate-100" %>

<article class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm shadow-slate-200/70 sm:rounded-3xl sm:p-6 lg:p-7">
  <div class="flex items-start justify-between gap-2">
    <time class="shrink-0 text-sm font-extrabold text-blue-700 sm:text-base" datetime="<%= fixture.match_date.iso8601 %>">
      <%= fixture.match_date.in_time_zone("Pacific Time (US & Canada)").strftime("%-I:%M %p") %>
    </time>

    <div class="flex min-w-0 items-center gap-3">
      <p class="flex min-w-0 items-center gap-1 text-right text-sm text-slate-500">
        <span class="min-w-0 truncate"><%= venue(fixture.location) %></span>
        <% if fixture_stage(fixture).present? %>
          <span class="shrink-0">·</span>
          <%= link_to fixture_stage(fixture), fixture_stage_path(fixture), class: "shrink-0 font-bold text-blue-700 transition hover:text-blue-800" %>
        <% end %>
      </p>
      <%= link_to "Predictions →", fixture_path(fixture), class: "shrink-0 text-sm font-bold text-blue-700 transition hover:text-blue-800" %>
    </div>
  </div>

  <% if open %>
    <%= form_with model: prediction, url: fixture_prediction_path(fixture), class: row do |form| %>
      <div class="<%= scoreline %> text-sm font-black leading-tight text-slate-950 sm:text-2xl lg:text-3xl">
        <span class="min-w-0 break-words text-right"><%= team_name_with_flag(fixture.home_team) %></span>
        <%= form.number_field :home_score, min: 0, required: true, class: score_input %>
        <span class="text-center text-slate-400">–</span>
        <%= form.number_field :away_score, min: 0, required: true, class: score_input %>
        <span class="min-w-0 break-words"><%= team_name_with_flag(fixture.away_team) %></span>
      </div>
      <%= form.submit prediction.persisted? ? "Update" : "Save", class: primary_button %>
    <% end %>
  <% elsif prediction.persisted? %>
    <div class="<%= row %>">
      <div class="<%= scoreline %> text-sm font-black leading-tight text-slate-950 sm:text-2xl lg:text-3xl">
        <span class="min-w-0 break-words text-right"><%= team_name_with_flag(fixture.home_team) %></span>
        <span class="text-center"><%= prediction.home_score %></span>
        <span class="text-center text-slate-400">–</span>
        <span class="text-center"><%= prediction.away_score %></span>
        <span class="min-w-0 break-words"><%= team_name_with_flag(fixture.away_team) %></span>
      </div>
      <span class="hidden sm:block"></span>
    </div>
  <% else %>
    <div class="mt-3 grid gap-1 text-lg font-black leading-tight text-slate-950 sm:grid-cols-[minmax(0,1fr)_auto_minmax(0,1fr)] sm:items-baseline sm:gap-4 sm:text-2xl lg:text-3xl">
      <span class="min-w-0 break-words sm:text-right"><%= team_name_with_flag(fixture.home_team) %></span>
      <span class="text-sm font-black uppercase tracking-wide text-slate-400 sm:text-xl sm:normal-case sm:tracking-normal">vs</span>
      <span class="min-w-0 break-words"><%= team_name_with_flag(fixture.away_team) %></span>
    </div>
  <% end %>

  <% if admin %>
    <%= form_with model: fixture, url: fixture_result_path(fixture), method: :patch, class: "#{row} #{result_panel}" do |form| %>
      <div class="<%= scoreline %> text-sm font-bold text-slate-600">
        <span class="text-right">Actual result</span>
        <%= form.number_field :home_score, min: 0, class: result_input %>
        <span class="text-center font-black text-slate-400">–</span>
        <%= form.number_field :away_score, min: 0, class: result_input %>
        <span></span>
      </div>
      <%= form.submit "Save result", class: secondary_button %>
    <% end %>

    <% if fixture.result? %>
      <% breakdown = prediction.persisted? ? prediction.point_breakdown : [] %>
      <details class="group mt-2">
        <summary class="cursor-pointer list-none text-sm font-black text-slate-700 marker:hidden">
          Points: <%= prediction.persisted? ? prediction.points : 0 %>
          <span class="text-slate-400 group-open:hidden">▾</span>
          <span class="hidden text-slate-400 group-open:inline">▴</span>
        </summary>
        <p class="mt-1 text-sm font-semibold text-slate-500">
          <% if breakdown.any? %>
            <%= breakdown.map { |part| "#{part[:points]} (#{part[:label]})" }.join(" + ") %>
          <% else %>
            No prediction entered.
          <% end %>
        </p>
      </details>
    <% end %>
  <% elsif fixture.result? %>
    <div class="<%= result_panel %> mt-3 flex flex-wrap items-center justify-between gap-x-4 gap-y-1">
      <div class="flex items-center gap-2 text-sm font-bold text-slate-600">
        <span>Actual result</span>
        <span class="text-lg font-black text-slate-950"><%= fixture.home_score %></span>
        <span class="font-black text-slate-400">–</span>
        <span class="text-lg font-black text-slate-950"><%= fixture.away_score %></span>
      </div>

      <% if signed_in %>
        <% breakdown = prediction.persisted? ? prediction.point_breakdown : [] %>
        <details class="group">
          <summary class="cursor-pointer list-none text-sm font-black text-slate-700 marker:hidden">
            Points: <%= prediction.persisted? ? prediction.points : 0 %>
            <span class="text-slate-400 group-open:hidden">▾</span>
            <span class="hidden text-slate-400 group-open:inline">▴</span>
          </summary>
          <p class="mt-1 text-sm font-semibold text-slate-500">
            <% if breakdown.any? %>
              <%= breakdown.map { |part| "#{part[:points]} (#{part[:label]})" }.join(" + ") %>
            <% else %>
              No prediction entered.
            <% end %>
          </p>
        </details>
      <% end %>
    </div>
  <% end %>

  <% if !signed_in %>
    <%= link_to "Sign in to predict", new_session_path, class: "mt-4 inline-block rounded-xl bg-slate-950 px-4 py-3 text-sm font-black text-white transition hover:bg-slate-800" %>
  <% elsif fixture.locked? && !prediction.persisted? %>
    <p class="mt-4 text-sm font-bold text-slate-500">Prediction locked · No prediction entered.</p>
  <% end %>
</article>
