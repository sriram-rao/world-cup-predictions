<% prediction = predictions_by_fixture_id[fixture.id] || Prediction.new(fixture: fixture) %>
<% signed_in = authenticated? %>
<% admin = admin_mode? %>
<% open = signed_in && !fixture.locked? %>
<% row = "mt-3 grid gap-3 sm:grid-cols-[minmax(0,1fr)_8rem] sm:items-center" %>
<% scoreline = "grid grid-cols-[minmax(0,1fr)_3rem_1rem_3rem_minmax(0,1fr)] items-center gap-2 sm:grid-cols-[minmax(0,1fr)_4rem_1rem_4rem_minmax(0,1fr)] sm:gap-3" %>
<% result_scoreline = "grid grid-cols-[minmax(0,1fr)_auto_auto_auto_minmax(0,1fr)] items-center gap-1" %>
<% score_input = "h-10 w-10 justify-self-center rounded-lg border border-slate-300 bg-white px-0 text-center text-sm font-black leading-none outline-none [appearance:textfield] focus:border-blue-600 focus:ring-4 focus:ring-blue-100 [&::-webkit-inner-spin-button]:appearance-none [&::-webkit-outer-spin-button]:appearance-none" %>
<% result_input = "h-8 w-9 justify-self-center rounded-lg border border-slate-300 bg-white px-1 text-center text-sm font-black text-slate-950 outline-none focus:border-blue-600 focus:ring-4 focus:ring-blue-100 sm:h-9 sm:w-12 sm:text-base" %>
<% panel = "mt-3 border-t border-slate-200 pt-3" %>
<% primary_button = "w-full cursor-pointer rounded-xl bg-slate-950 px-4 py-3 text-sm font-black text-white transition hover:bg-slate-800" %>
<% secondary_button = "result-save-button w-full cursor-pointer rounded-xl px-4 py-2 text-sm font-black transition" %>
<% breakdown = prediction.persisted? ? prediction.point_breakdown : [] %>
<% points = prediction.persisted? ? prediction.points : 0 %>
<% points_explanation = breakdown.any? ? breakdown.map { |part| "#{part[:points]} (#{part[:label]})" }.join(" + ") : "No prediction entered." %>

<article class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm shadow-slate-200/70 sm:rounded-3xl sm:p-6 lg:p-7">
  <div class="grid grid-cols-[auto_minmax(0,1fr)_auto] items-start gap-2">
    <time class="shrink-0 text-sm font-extrabold text-amber-600 sm:text-base" datetime="<%= fixture.match_date.iso8601 %>" data-local-time="time">
      <%= fixture.match_date.in_time_zone("Pacific Time (US & Canada)").strftime("%-I:%M %p PT") %>
    </time>

    <p class="min-w-0 truncate text-center text-sm text-slate-500"><%= venue(fixture.location) %></p>

    <div class="flex justify-end">
      <details class="relative shrink-0" data-click-outside-close>
        <summary class="list-none rounded-lg border border-slate-200 bg-white px-2.5 py-1 text-sm font-black text-slate-600 shadow-sm marker:hidden">…</summary>
        <div class="absolute right-0 z-10 mt-2 w-48 overflow-hidden rounded-2xl border border-slate-200 bg-white text-sm font-bold text-slate-700 shadow-xl">
          <% if fixture_stage(fixture).present? %>
            <%= link_to fixture_stage(fixture), fixture_stage_path(fixture), class: "block border-b border-slate-100 px-4 py-3 transition hover:bg-slate-50" %>
          <% end %>
          <%= link_to "All Predictions", fixture_path(fixture), class: "block border-b border-slate-100 px-4 py-3 transition hover:bg-slate-50" %>
          <% if admin %>
            <button type="button" class="w-full px-4 py-3 text-left font-bold transition hover:bg-slate-50" onclick="document.getElementById('result-dialog-<%= fixture.id %>').showModal()">
              Edit result
            </button>
          <% end %>
        </div>
      </details>
    </div>
  </div>

  <% if fixture.result? %>
    <div class="mt-3 flex flex-wrap items-center justify-center gap-x-1.5 gap-y-1 py-1 text-center text-sm font-black leading-tight text-slate-950 sm:text-xl">
      <span><%= team_name_with_flag(fixture.home_team) %></span>
      <span><%= fixture.home_score %></span>
      <span class="text-slate-400">–</span>
      <span><%= fixture.away_score %></span>
      <span><%= team_name_with_flag(fixture.away_team) %></span>
    </div>
  <% else %>
    <div class="mt-3 flex flex-wrap items-center justify-center gap-x-1.5 gap-y-1 text-center text-sm font-black leading-tight text-slate-950 sm:text-xl">
      <span><%= team_name_with_flag(fixture.home_team) %></span>
      <span class="text-slate-400">v</span>
      <span><%= team_name_with_flag(fixture.away_team) %></span>
    </div>
  <% end %>

  <% if signed_in %>
    <section class="<%= panel %>">
      <div class="flex items-center justify-between gap-4">
        <p class="text-sm font-black text-slate-700">Your prediction</p>
        <p class="text-sm font-black text-slate-700">Points</p>
      </div>

      <% if open %>
        <%= form_with model: prediction, url: fixture_prediction_path(fixture), class: "mt-2" do |form| %>
          <div class="flex items-center justify-between gap-4">
            <div class="flex items-center gap-2">
              <%= form.number_field :home_score, min: 0, required: true, class: score_input %>
              <span class="font-black text-slate-400">–</span>
              <%= form.number_field :away_score, min: 0, required: true, class: score_input %>
            </div>

            <% if fixture.result? %>
              <details class="group relative text-right" data-click-outside-close>
                <summary class="cursor-pointer list-none text-sm font-black text-slate-950 marker:hidden"><%= points %></summary>
                <div class="absolute right-0 top-full z-10 mt-2 hidden w-48 rounded-xl border border-slate-200 bg-white px-3 py-2 text-left text-sm font-semibold text-slate-500 shadow-xl group-hover:block group-open:block">
                  <%= points_explanation %>
                </div>
              </details>
            <% else %>
              <span class="text-sm font-black text-slate-400">—</span>
            <% end %>
          </div>
          <div class="mt-2 flex justify-center">
            <%= form.submit prediction.persisted? ? "Update" : "Save", class: "w-full cursor-pointer rounded-xl bg-slate-950 px-4 py-2 text-sm font-black text-white transition hover:bg-slate-800 sm:w-auto" %>
          </div>
        <% end %>
      <% elsif prediction.persisted? %>
        <div class="mt-1 flex items-center justify-between gap-4">
          <div class="flex items-center gap-2 text-sm font-bold text-slate-600">
            <span class="text-sm font-black text-slate-950"><%= prediction.home_score %></span>
            <span class="font-black text-slate-400">–</span>
            <span class="text-sm font-black text-slate-950"><%= prediction.away_score %></span>
          </div>

          <% if fixture.result? %>
            <details class="group relative text-right" data-click-outside-close>
              <summary class="cursor-pointer list-none text-sm font-black text-slate-950 marker:hidden"><%= points %></summary>
              <div class="absolute right-0 top-full z-10 mt-2 hidden w-48 rounded-xl border border-slate-200 bg-white px-3 py-2 text-left text-sm font-semibold text-slate-500 shadow-xl group-hover:block group-open:block">
                <%= points_explanation %>
              </div>
            </details>
          <% else %>
            <span class="text-sm font-black text-slate-400">—</span>
          <% end %>
        </div>
      <% else %>
        <div class="mt-1 flex items-center justify-between gap-4">
          <p class="text-sm font-bold text-slate-500"><%= fixture.locked? ? "Prediction locked · No prediction entered." : "No prediction entered." %></p>
          <% if fixture.result? %>
            <details class="group relative text-right" data-click-outside-close>
              <summary class="cursor-pointer list-none text-sm font-black text-slate-950 marker:hidden">0</summary>
              <div class="absolute right-0 top-full z-10 mt-2 hidden w-48 rounded-xl border border-slate-200 bg-white px-3 py-2 text-left text-sm font-semibold text-slate-500 shadow-xl group-hover:block group-open:block">
                No prediction entered.
              </div>
            </details>
          <% else %>
            <span class="text-sm font-black text-slate-400">—</span>
          <% end %>
        </div>
      <% end %>
    </section>
  <% end %>

  <% if admin %>
    <dialog id="result-dialog-<%= fixture.id %>" class="fixed inset-0 m-auto w-[min(92vw,24rem)] rounded-3xl border border-slate-200 bg-white p-0 text-slate-950 backdrop:bg-slate-950/70">
      <div class="p-5">
        <div class="mb-4 flex items-start justify-between gap-4">
          <div>
            <h3 class="text-xl font-black">Edit result</h3>
            <p class="mt-1 text-sm text-slate-500"><%= team_name_with_flag(fixture.home_team) %> v <%= team_name_with_flag(fixture.away_team) %></p>
          </div>
          <button type="button" class="text-xl font-black text-slate-400" onclick="this.closest('dialog').close()">×</button>
        </div>

        <%= form_with model: fixture, url: fixture_result_path(fixture), method: :patch, class: "space-y-4" do |form| %>
          <div class="grid grid-cols-[1fr_auto_1fr] items-center gap-3">
            <%= form.number_field :home_score, min: 0, class: result_input %>
            <span class="font-black text-slate-400">–</span>
            <%= form.number_field :away_score, min: 0, class: result_input %>
          </div>
          <%= form.submit "Save result", class: secondary_button %>
        <% end %>
      </div>
    </dialog>
  <% end %>
</article>
