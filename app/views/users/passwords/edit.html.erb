<main class="flex min-h-screen items-center justify-center bg-slate-50 px-4 py-12 sm:px-6 lg:px-8">
  <section class="w-full max-w-md rounded-3xl border border-slate-200 bg-white p-6 shadow-sm shadow-slate-200/70 sm:p-8">
    <% description = capture do %>
      Setting new password for <span class="font-bold text-slate-950"><%= @user.username %></span>.
    <% end %>

    <%= render "shared/page_header", title: "Reset password", description: description, title_class: "text-3xl font-black tracking-tight text-slate-950 sm:text-4xl" %>

    <% if flash[:alert].present? %>
      <div class="mb-5 rounded-2xl border border-red-200 bg-red-50 px-4 py-3 text-sm font-medium text-red-700"><%= flash[:alert] %></div>
    <% end %>

    <%= form_with url: user_password_path(@user), method: :patch, class: "space-y-5" do |form| %>
      <div>
        <%= form.label :password, "New password", class: "block text-sm font-bold text-slate-700" %>
        <%= form.password_field :password, required: true, autocomplete: "new-password", maxlength: 72,
          class: "mt-2 w-full rounded-2xl border border-slate-300 bg-white px-4 py-3 text-slate-950 outline-none transition placeholder:text-slate-400 focus:border-blue-600 focus:ring-4 focus:ring-blue-100" %>
      </div>

      <div>
        <%= form.label :password_confirmation, "Confirm password", class: "block text-sm font-bold text-slate-700" %>
        <%= form.password_field :password_confirmation, required: true, autocomplete: "new-password", maxlength: 72,
          class: "mt-2 w-full rounded-2xl border border-slate-300 bg-white px-4 py-3 text-slate-950 outline-none transition placeholder:text-slate-400 focus:border-blue-600 focus:ring-4 focus:ring-blue-100" %>
      </div>

      <%= form.submit "Reset password", class: "w-full cursor-pointer rounded-2xl bg-slate-950 px-5 py-3 text-sm font-black text-white shadow-sm transition hover:bg-slate-800" %>
    <% end %>

    <%= link_to "← Cancel", leaderboard_path, class: "mt-4 block text-center text-sm font-bold text-slate-500 hover:text-slate-950" %>
  </section>
</main>
